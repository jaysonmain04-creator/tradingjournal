<h1>Trading Calendar</h1>

<div class="section">

  <div class="analytics-grid" id="analytics-grid"></div>
  <div class="streak-grid"    id="streak-grid"></div>

  <div class="controls">
    <div class="month-nav">
      <button class="nav-btn" onclick="prevMonth()">&#8249;</button>
      <div class="month-label" id="month-label"></div>
      <button class="nav-btn" onclick="nextMonth()">&#8250;</button>
      <button class="nav-btn" onclick="goToday()" style="font-size:12px;padding:5px 10px;">Today</button>
    </div>
    <div class="view-toggle">
      <button class="view-btn active" id="btn-calendar" onclick="setView('calendar')">Calendar</button>
      <button class="view-btn"        id="btn-heatmap"  onclick="setView('heatmap')">Heatmap</button>
    </div>
    <div class="filters">
      <select class="filter-select" id="f-pair"   onchange="applyFilters()">
        <option value="">All Pairs</option>
        <option value="NQ">NQ</option>
        <option value="ES">ES</option>
      </select>
      <select class="filter-select" id="f-result" onchange="applyFilters()">
        <option value="">All Results</option>
        <option value="Win">Win</option>
        <option value="Loss">Loss</option>
        <option value="BE">BE</option>
        <option value="No Trade">No Trade</option>
      </select>
      <select class="filter-select" id="f-grade"  onchange="applyFilters()">
        <option value="">All Grades</option>
        <option value="A+">A+</option>
        <option value="A">A</option>
        <option value="A-">A-</option>
        <option value="B+">B+</option>
        <option value="B">B</option>
        <option value="B-">B-</option>
        <option value="C">C</option>
      </select>
      <select class="filter-select" id="f-type"   onchange="applyFilters()">
        <option value="">All Types</option>
        <option value="Reversal">Reversal</option>
        <option value="Continuation">Continuation</option>
      </select>
    </div>
  </div>

  <!-- Calendar view -->
  <div id="calendar-view">
    <div class="cal-dow-row">
      <div class="cal-dow">Sun</div><div class="cal-dow">Mon</div>
      <div class="cal-dow">Tue</div><div class="cal-dow">Wed</div>
      <div class="cal-dow">Thu</div><div class="cal-dow">Fri</div>
      <div class="cal-dow">Sat</div>
    </div>
    <div class="cal-grid" id="cal-grid"></div>
  </div>

  <!-- Heatmap view -->
  <div id="heatmap-view">
    <div class="heatmap-scroll">
      <div class="hm-wrap" id="hm-wrap"></div>
    </div>
    <div class="hm-legend">
      <span>Performance:</span>
      <div class="hm-legend-item"><div class="hm-legend-swatch" style="background:#1b4a1e"></div>Win</div>
      <div class="hm-legend-item"><div class="hm-legend-swatch" style="background:#4caf50"></div>Strong Win</div>
      <div class="hm-legend-item"><div class="hm-legend-swatch" style="background:#4a1818"></div>Loss</div>
      <div class="hm-legend-item"><div class="hm-legend-swatch" style="background:#e53935"></div>Heavy Loss</div>
      <div class="hm-legend-item"><div class="hm-legend-swatch" style="background:#1a3a5a"></div>BE/Mixed</div>
      <div class="hm-legend-item"><div class="hm-legend-swatch" style="background:#2a2030"></div>No Trade</div>
      <div class="hm-legend-item"><div class="hm-legend-swatch" style="background:#1a0a0d"></div>No Data</div>
    </div>
  </div>

</div>

<div id="day-overlay" onclick="closeDayPanel()"></div>
<div id="day-panel">
  <div class="dp-header">
    <div>
      <div class="dp-title"    id="dp-title">—</div>
      <div class="dp-subtitle" id="dp-subtitle">—</div>
    </div>
    <button class="dp-close" onclick="closeDayPanel()">&#10005;</button>
  </div>
  <div class="dp-body" id="dp-body"></div>
</div>

<div id="lightbox">
  <button id="lb-close" onclick="closeLightbox()">&#10005;</button>
  <img id="lb-img" src="" alt="chart">
</div>

<script>
// ── State ──
let allTrades   = [];
let tradesByDay = {};
let viewYear, viewMonth;
let currentView = "calendar";

const MONTHS       = ["January","February","March","April","May","June","July","August","September","October","November","December"];
const MONTHS_SHORT = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
const CL_KEYS      = ["sweep","ifvg","valid","target","pd","momentum"];
const CL_LABELS    = ["BSL/SSL","IFVG","Valid Entry","Clear DOL","P/D","No Chop"];

// ── Utils ──
function parseDate(str) {
  if (!str) return null;
  const d = new Date(str);
  return isNaN(d.getTime()) ? null : d;
}

function dateKey(d) {
  return d.getFullYear() + "-" +
    String(d.getMonth() + 1).padStart(2,"0") + "-" +
    String(d.getDate()).padStart(2,"0");
}

function todayKey() { return dateKey(new Date()); }

function gradeColor(g) {
  return { "A+":"#4caf50","A":"#66bb6a","A-":"#8bc34a","B+":"#ffa726","B":"#ff7043","B-":"#e53935","C":"#b71c1c" }[g] || "#888";
}

function resultColor(r) {
  return { "Win":"#4caf50","Loss":"#e53935","BE":"#42a5f5" }[r] || "#888";
}

function calcQS(t) {
  const cl   = t.checklist ? Object.values(t.checklist).filter(Boolean).length : 0;
  const conf = t.confidence || 0;
  return Math.round((cl / 6) * 6 + (conf / 10) * 4);
}

function parseRR(rr) {
  if (!rr || !rr.trim()) return null;
  const m1 = rr.match(/1:(\d+\.?\d*)/);
  if (m1) return parseFloat(m1[1]);
  const m2 = rr.match(/^(\d+\.?\d*)/);
  return m2 ? parseFloat(m2[1]) : null;
}

// ── Data ──
function loadData() {
  allTrades = JSON.parse(localStorage.getItem("trades")) || [];
  applyFilters();
}

function applyFilters() {
  const pair   = document.getElementById("f-pair").value;
  const result = document.getElementById("f-result").value;
  const grade  = document.getElementById("f-grade").value;
  const type   = document.getElementById("f-type").value;

  const filtered = allTrades.filter(t => {
    if (pair   && t.pair      !== pair)   return false;
    if (result && t.result    !== result) return false;
    if (grade  && t.grade     !== grade)  return false;
    if (type   && t.tradeType !== type)   return false;
    return true;
  });

  tradesByDay = {};
  filtered.forEach(t => {
    const d = parseDate(t.datetime);
    if (!d) return;
    const k = dateKey(d);
    if (!tradesByDay[k]) tradesByDay[k] = [];
    tradesByDay[k].push(t);
  });

  renderAll();
}

// ── Day classification ──
function dayClass(dayTrades) {
  const real   = dayTrades.filter(t => t.result !== "No Trade");
  const wins   = real.filter(t => t.result === "Win").length;
  const losses = real.filter(t => t.result === "Loss").length;
  const bes    = real.filter(t => t.result === "BE").length;
  if (!real.length)          return "day-notrade";
  if (wins > losses)         return "day-win";
  if (losses > wins)         return "day-loss";
  if (bes && !wins && !losses) return "day-be";
  return "day-mixed";
}

function hasViolation(dayTrades) {
  return dayTrades.some(t => t.result !== "No Trade" && t.grade === "C");
}

// ── Analytics ──
function renderAnalytics() {
  const real     = allTrades.filter(t => t.result && t.result !== "No Trade");
  const wins     = real.filter(t => t.result === "Win");
  const winRate  = real.length ? Math.round((wins.length / real.length) * 100) : null;

  const confTs  = real.filter(t => t.confidence);
  const avgConf = confTs.length ? (confTs.reduce((s,t)=>s+t.confidence,0)/confTs.length).toFixed(1) : null;

  const avgQS   = real.length ? Math.round(real.reduce((s,t)=>s+calcQS(t),0)/real.length) : null;

  const rrTs    = real.filter(t => parseRR(t.rr) !== null);
  const avgRR   = rrTs.length ? (rrTs.reduce((s,t)=>s+parseRR(t.rr),0)/rrTs.length).toFixed(1) : null;

  const gradeOrder = ["A+","A","A-","B+","B","B-","C"];
  let bestGrade = null;
  for (const g of gradeOrder) { if (real.some(t=>t.grade===g)) { bestGrade=g; break; } }

  const pairMap = {};
  allTrades.filter(t=>t.pair).forEach(t=>{ pairMap[t.pair]=(pairMap[t.pair]||0)+1; });
  const topPair = Object.entries(pairMap).sort((a,b)=>b[1]-a[1])[0];

  const clTs    = real.filter(t=>t.checklist);
  const fullCL  = clTs.filter(t=>Object.values(t.checklist).every(Boolean));
  const ruleRate= clTs.length ? Math.round((fullCL.length/clTs.length)*100) : null;

  const cards = [
    { label:"Total Trades",       val: real.length,           sub: allTrades.length+" entries total" },
    { label:"Win Rate",           val: winRate!==null?winRate+"%":"—", sub:"wins / trades taken", col: winRate>=50?"#4caf50":winRate!==null?"#e53935":null },
    { label:"Avg Confidence",     val: avgConf!==null?avgConf+"/10":"—", sub:"across rated trades" },
    { label:"Avg Quality Score",  val: avgQS!==null?avgQS+"/10":"—",   sub:"checklist + confidence" },
    { label:"Avg RR",             val: avgRR!==null?avgRR+"R":"—",      sub:"risk / reward taken" },
    { label:"Best Grade",         val: bestGrade||"—",                  sub:"highest setup quality", col: bestGrade?gradeColor(bestGrade):null },
    { label:"Top Pair",           val: topPair?topPair[0]:"—",          sub:"most traded" },
    { label:"Rule Follow Rate",   val: ruleRate!==null?ruleRate+"%":"—",sub:"full checklist trades", col: ruleRate>=70?"#4caf50":ruleRate!==null?"#ffa726":null },
  ];

  document.getElementById("analytics-grid").innerHTML = cards.map(c=>
    `<div class="stat-card">
      <div class="stat-label">${c.label}</div>
      <div class="stat-val"${c.col?` style="color:${c.col}"`:""}>${c.val}</div>
      <div class="stat-sub">${c.sub}</div>
    </div>`
  ).join("");
}

// ── Streaks ──
function renderStreaks() {
  const keys = Object.keys(tradesByDay).sort();
  let wC=0,wM=0, rC=0,rM=0, cC=0,cM=0, lC=0,lM=0;

  for (const k of keys) {
    const day  = tradesByDay[k];
    const real = day.filter(t=>t.result!=="No Trade");
    const wins = real.filter(t=>t.result==="Win").length;
    const loss = real.filter(t=>t.result==="Loss").length;

    if (real.length) {
      if (wins>loss) { wC++; wM=Math.max(wM,wC); } else wC=0;
      const hasC = real.some(t=>t.grade==="C");
      if (!hasC) { rC++; rM=Math.max(rM,rC); } else rC=0;
      const confTs = real.filter(t=>t.confidence);
      if (confTs.length) {
        const avg = confTs.reduce((s,t)=>s+t.confidence,0)/confTs.length;
        if (avg>=7) { cC++; cM=Math.max(cM,cC); } else cC=0;
      }
    }
    lC++; lM=Math.max(lM,lC);
  }

  const streaks = [
    { icon:"🔥", label:"Win Streak",           cur:wC, max:wM, col:wC?"#4caf50":"#888" },
    { icon:"✅", label:"Rule Follow Streak",    cur:rC, max:rM, col:rC?"#ffa726":"#888" },
    { icon:"🎯", label:"High Confidence Streak",cur:cC, max:cM, col:cC?"#42a5f5":"#888" },
    { icon:"📅", label:"Logging Streak",        cur:lC, max:lM, col:lC?"#ce93d8":"#888" },
  ];

  document.getElementById("streak-grid").innerHTML = streaks.map(s=>
    `<div class="streak-card">
      <div class="streak-icon">${s.icon}</div>
      <div class="streak-info">
        <div class="streak-label">${s.label}</div>
        <div class="streak-val" style="color:${s.col}">${s.cur} days</div>
        <div class="streak-max">Best: ${s.max} days</div>
      </div>
    </div>`
  ).join("");
}

// ── Calendar ──
function renderCalendar() {
  document.getElementById("month-label").textContent = MONTHS[viewMonth] + " " + viewYear;
  const grid     = document.getElementById("cal-grid");
  grid.innerHTML = "";

  const todKey     = todayKey();
  const firstDay   = new Date(viewYear, viewMonth, 1).getDay();
  const daysInMonth= new Date(viewYear, viewMonth+1, 0).getDate();

  for (let i=0; i<firstDay; i++) {
    const e = document.createElement("div");
    e.className = "day-cell empty";
    grid.appendChild(e);
  }

  for (let d=1; d<=daysInMonth; d++) {
    const key = viewYear + "-" +
      String(viewMonth+1).padStart(2,"0") + "-" +
      String(d).padStart(2,"0");
    const dayTrades = tradesByDay[key] || [];
    const isToday   = key === todKey;

    const cell = document.createElement("div");
    cell.className = "day-cell" +
      (dayTrades.length ? " "+dayClass(dayTrades) : "") +
      (isToday ? " today" : "");
    cell.onclick = ()=>openDayPanel(key);

    if (dayTrades.length && hasViolation(dayTrades)) {
      const vb = document.createElement("div");
      vb.className = "violation-badge";
      vb.title     = "C-grade trade detected";
      vb.textContent = "⚠";
      cell.appendChild(vb);
    }

    const numEl = document.createElement("div");
    numEl.className   = "day-num";
    numEl.textContent = d;
    cell.appendChild(numEl);

    if (dayTrades.length) {
      const pipsEl = document.createElement("div");
      pipsEl.className = "day-pips";
      dayTrades.slice(0,10).forEach(t=>{
        const p = document.createElement("div");
        p.className = "pip pip-" + (t.result==="Win"?"win":t.result==="Loss"?"loss":t.result==="BE"?"be":"notrade");
        pipsEl.appendChild(p);
      });
      if (dayTrades.length>10) {
        const m = document.createElement("div");
        m.style.cssText = "font-size:9px;color:#666;align-self:flex-end;line-height:7px;";
        m.textContent   = "+"+( dayTrades.length-10);
        pipsEl.appendChild(m);
      }
      cell.appendChild(pipsEl);

      const real   = dayTrades.filter(t=>t.result!=="No Trade");
      const wins   = real.filter(t=>t.result==="Win").length;
      const losses = real.filter(t=>t.result==="Loss").length;
      const bes    = real.filter(t=>t.result==="BE").length;
      const nts    = dayTrades.filter(t=>t.result==="No Trade").length;

      const parts = [];
      if (wins)              parts.push(wins+"W");
      if (losses)            parts.push(losses+"L");
      if (bes)               parts.push(bes+"BE");
      if (nts && !real.length) parts.push("No Trade");

      const infoEl = document.createElement("div");
      infoEl.className   = "day-info";
      infoEl.textContent = parts.join(" · ");

      const gradeOrder = ["A+","A","A-","B+","B","B-","C"];
      const grades     = dayTrades.filter(t=>t.grade).map(t=>t.grade);
      for (const g of gradeOrder) {
        if (grades.includes(g)) {
          const gb = document.createElement("div");
          gb.className  = "day-grade-badge";
          gb.style.color= gradeColor(g);
          gb.textContent= g;
          infoEl.appendChild(gb);
          break;
        }
      }
      cell.appendChild(infoEl);

      // Native tooltip
      const tipParts = [parts.join(" · ")];
      const avgConfs = dayTrades.filter(t=>t.confidence);
      if (avgConfs.length) {
        const a = (avgConfs.reduce((s,t)=>s+t.confidence,0)/avgConfs.length).toFixed(1);
        tipParts.push("Avg Conf: "+a+"/10");
      }
      cell.title = tipParts.join(" | ");
    }

    grid.appendChild(cell);
  }
}

// ── Heatmap ──
function renderHeatmap() {
  const wrap     = document.getElementById("hm-wrap");
  wrap.innerHTML = "";

  // Last 52 weeks from today
  const end   = new Date();
  const start = new Date(end);
  start.setDate(start.getDate() - 364);
  start.setDate(start.getDate() - start.getDay()); // align to Sunday

  // Build week columns
  const weeks = [];
  let cur = new Date(start);
  while (cur <= end) {
    const week = [];
    for (let d=0; d<7; d++) {
      week.push(new Date(cur));
      cur.setDate(cur.getDate()+1);
    }
    weeks.push(week);
  }

  // Month labels row
  const mlRow = document.createElement("div");
  mlRow.className = "hm-month-labels";
  // spacer for day-label column
  const spacer = document.createElement("div");
  spacer.style.cssText = "width:28px;flex-shrink:0;";
  mlRow.appendChild(spacer);

  let lastMo = -1;
  weeks.forEach(week => {
    const mo  = week[0].getMonth();
    const lbl = document.createElement("div");
    lbl.className   = "hm-month-label-cell";
    lbl.textContent = mo !== lastMo ? MONTHS_SHORT[mo] : "";
    if (mo !== lastMo) lastMo = mo;
    mlRow.appendChild(lbl);
  });
  wrap.appendChild(mlRow);

  // Body
  const body = document.createElement("div");
  body.className = "hm-body";

  // Day labels
  const dayLabels = document.createElement("div");
  dayLabels.className = "hm-day-labels";
  ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"].forEach((d,i)=>{
    const el = document.createElement("div");
    el.className   = "hm-day-label";
    el.textContent = (i===0||i===2||i===4) ? d : "";
    dayLabels.appendChild(el);
  });
  body.appendChild(dayLabels);

  // Weeks
  const weeksEl = document.createElement("div");
  weeksEl.className = "hm-weeks";

  weeks.forEach(week => {
    const weekEl = document.createElement("div");
    weekEl.className = "hm-week";

    week.forEach(date => {
      const k         = dateKey(date);
      const dayTrades = tradesByDay[k] || [];
      const cell      = document.createElement("div");
      cell.className  = "hm-cell";

      if (dayTrades.length) {
        cell.classList.add("clickable");
        const real   = dayTrades.filter(t=>t.result!=="No Trade");
        const wins   = real.filter(t=>t.result==="Win").length;
        const losses = real.filter(t=>t.result==="Loss").length;
        const nts    = dayTrades.filter(t=>t.result==="No Trade").length;

        let bg = "#1a3a5a"; // default: BE/mixed
        if (nts === dayTrades.length)       bg = "#2a2030";
        else if (wins > losses*1.5)         bg = "#4caf50";
        else if (wins > losses)             bg = "#2d7a32";
        else if (wins>0 && losses===0)      bg = "#1b4a1e";
        else if (losses > wins*1.5)         bg = "#e53935";
        else if (losses > wins)             bg = "#7a2020";
        else if (losses>0 && wins===0)      bg = "#4a1818";

        cell.style.background = bg;
        cell.title = MONTHS_SHORT[date.getMonth()]+" "+date.getDate()+" — "+wins+"W "+losses+"L"+(nts?" "+nts+"NT":"");
        cell.onclick = ()=>openDayPanel(k);
      } else {
        cell.title = MONTHS_SHORT[date.getMonth()]+" "+date.getDate()+" — No data";
      }

      weekEl.appendChild(cell);
    });

    weeksEl.appendChild(weekEl);
  });

  body.appendChild(weeksEl);
  wrap.appendChild(body);
}

// ── View toggle ──
function setView(v) {
  currentView = v;
  document.getElementById("calendar-view").style.display = v==="calendar" ? "" : "none";
  document.getElementById("heatmap-view").style.display  = v==="heatmap"  ? "" : "none";
  document.getElementById("btn-calendar").classList.toggle("active", v==="calendar");
  document.getElementById("btn-heatmap").classList.toggle("active",  v==="heatmap");
  if (v==="heatmap") renderHeatmap();
}

// ── Month nav ──
function prevMonth() { if (--viewMonth<0) { viewMonth=11; viewYear--; } renderCalendar(); }
function nextMonth() { if (++viewMonth>11){ viewMonth=0;  viewYear++; } renderCalendar(); }
function goToday()   { const n=new Date(); viewYear=n.getFullYear(); viewMonth=n.getMonth(); renderCalendar(); }

// ── Day panel ──
function openDayPanel(key) {
  const dayTrades = tradesByDay[key] || [];
  const [yr,mo,d] = key.split("-").map(Number);
  const dateStr   = new Date(yr,mo-1,d).toLocaleDateString("en-US",{weekday:"long",month:"long",day:"numeric",year:"numeric"});

  document.getElementById("dp-title").textContent    = dateStr;
  document.getElementById("dp-subtitle").textContent = dayTrades.length
    ? dayTrades.length+" entr"+(dayTrades.length===1?"y":"ies")+" logged"
    : "No trades logged";

  const body = document.getElementById("dp-body");

  if (!dayTrades.length) {
    body.innerHTML = `<div style="text-align:center;color:#555;margin-top:40px;font-size:14px;">No entries for this day.</div>`;
  } else {
    const real   = dayTrades.filter(t=>t.result!=="No Trade");
    const wins   = real.filter(t=>t.result==="Win").length;
    const losses = real.filter(t=>t.result==="Loss").length;
    const bes    = real.filter(t=>t.result==="BE").length;

    const confTs  = real.filter(t=>t.confidence);
    const avgConf = confTs.length ? (confTs.reduce((s,t)=>s+t.confidence,0)/confTs.length).toFixed(1) : null;
    const avgQS   = real.length   ? Math.round(real.reduce((s,t)=>s+calcQS(t),0)/real.length) : null;
    const confCol = avgConf>=8?"#4caf50":avgConf>=5?"#ffa726":avgConf?"#e53935":"#555";
    const qsCol   = avgQS>=8?"#4caf50":avgQS>=5?"#ffa726":avgQS>0?"#e53935":"#555";

    const gradeOrder = ["A+","A","A-","B+","B","B-","C"];
    let bestGrade = null;
    for (const g of gradeOrder) { if (real.some(t=>t.grade===g)) { bestGrade=g; break; } }

    let html = `<div class="dp-day-stats">
      <div class="dp-stat">
        <div class="dp-stat-label">Result</div>
        <div class="dp-stat-value">${wins}W &middot; ${losses}L &middot; ${bes}BE</div>
      </div>
      <div class="dp-stat">
        <div class="dp-stat-label">Avg Confidence</div>
        <div class="dp-stat-value" style="color:${confCol}">${avgConf?avgConf+"/10":"&mdash;"}</div>
      </div>
      <div class="dp-stat">
        <div class="dp-stat-label">Best Grade</div>
        <div class="dp-stat-value" style="color:${bestGrade?gradeColor(bestGrade):"#555"}">${bestGrade||"&mdash;"}</div>
      </div>
    </div>`;

    html += `<div class="dp-section-title">Trades</div>`;

    dayTrades.forEach(t => {
      const tcCls  = t.result==="Win"?"tc-win":t.result==="Loss"?"tc-loss":t.result==="BE"?"tc-be":"tc-notrade";
      const rCol   = resultColor(t.result);
      const conf   = t.confidence;
      const cCol   = conf>=8?"#4caf50":conf>=5?"#ffa726":conf?"#e53935":"#555";
      const qs     = calcQS(t);
      const qCol   = qs>=8?"#4caf50":qs>=5?"#ffa726":qs>0?"#e53935":"#555";

      const clHTML = t.checklist
        ? `<div class="tc-checklist">`+
          CL_KEYS.map((k,i)=>
            `<span class="tc-chip ${t.checklist[k]?"on":"off"}">${CL_LABELS[i]}</span>`
          ).join("")+`</div>`
        : "";

      let notesHTML = "";
      if (t.notes) {
        notesHTML = `<div class="tc-note-block"><div class="tc-note-label">Notes</div>`;
        t.notes.split("\n").forEach(line => {
          const ci = line.indexOf(": ");
          if (ci > -1) {
            notesHTML += `<div class="tc-note-line">
              <div class="tc-note-key">${line.slice(0,ci)}</div>
              <div class="tc-note-val">${line.slice(ci+2)}</div>
            </div>`;
          } else if (line.trim()) {
            notesHTML += `<div class="tc-note-val" style="margin-bottom:4px;">${line}</div>`;
          }
        });
        notesHTML += `</div>`;
      }

      const imgHTML = t.image
        ? `<img class="tc-img" src="${t.image}" alt="chart" onclick="openLightbox(this.src)">`
        : "";

      html += `<div class="trade-card ${tcCls}">
        <div class="tc-header">
          <div>
            <span class="tc-result" style="color:${rCol}">${t.result}</span>
            ${t.pair?`<span style="font-size:11px;color:#888;margin-left:8px;">${t.pair}</span>`:""}
            ${t.grade?`<span style="font-size:11px;font-weight:bold;color:${gradeColor(t.grade)};background:#1a0a0d;padding:1px 7px;border-radius:4px;margin-left:6px;">${t.grade}</span>`:""}
          </div>
          <div class="tc-meta">${t.datetime||""}</div>
        </div>
        <div class="tc-stats">
          ${t.rr?`<div class="tc-stat">RR <span>${t.rr}</span></div>`:""}
          ${t.tradeType?`<div class="tc-stat">Type <span>${t.tradeType}</span></div>`:""}
          ${conf?`<div class="tc-stat">Conf <span style="color:${cCol}">${conf}/10</span></div>`:""}
          ${(t.checklist||t.confidence)?`<div class="tc-stat">QS <span style="color:${qCol}">${qs}/10</span></div>`:""}
        </div>
        ${clHTML}
        ${notesHTML}
        ${imgHTML}
      </div>`;
    });

    body.innerHTML = html;
  }

  document.getElementById("day-panel").classList.add("open");
  document.getElementById("day-overlay").classList.add("open");
}

function closeDayPanel() {
  document.getElementById("day-panel").classList.remove("open");
  document.getElementById("day-overlay").classList.remove("open");
}

// ── Lightbox ──
function openLightbox(src) {
  document.getElementById("lb-img").src = src;
  document.getElementById("lightbox").classList.add("open");
}
function closeLightbox() {
  document.getElementById("lightbox").classList.remove("open");
  document.getElementById("lb-img").src = "";
}
document.getElementById("lightbox").addEventListener("click", function(e) {
  if (e.target === this) closeLightbox();
});

// ── Render all ──
function renderAll() {
  renderAnalytics();
  renderStreaks();
  if (currentView === "calendar") renderCalendar();
  else renderHeatmap();
}

// ── Init ──
const _now  = new Date();
viewYear    = _now.getFullYear();
viewMonth   = _now.getMonth();

loadData();

// Auto-refresh when trades are added from the journal tab
window.addEventListener("storage", function(e) {
  if (e.key === "trades") loadData();
});
